DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Local dev can use SQLite without setup. On Hostinger set DB_ENGINE=mysql.
DB_ENGINE=sqlite

# MySQL/MariaDB database used by Django when DB_ENGINE=mysql.
MYSQL_DATABASE=rough_wallets
MYSQL_USER=your_hostinger_db_user
MYSQL_PASSWORD=your_hostinger_db_password
MYSQL_HOST=your_hostinger_mysql_host
MYSQL_PORT=3306

# Put your real receiving wallet here.
PAYMENT_RECEIVER_ADDRESS=0x6B3A21807fEE4f04E525DaEBcc0ceC0fCbc3bf91

# Ethereum mainnet for real ETH payments. Use 11155111 for Sepolia testnet.
CHAIN_ID=1

# Required for backend transaction verification.
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
CONFIRMATION_BLOCKS=1

# Frontend
VITE_API_BASE=http://127.0.0.1:8000/api
